<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PublishAot>true</PublishAot>
    <InvariantGlobalization>true</InvariantGlobalization>
    <AssemblyName>crypto</AssemblyName>
    <Version>1.3.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BouncyCastle.Cryptography" Version="2.6.2" />
    <PackageReference Include="Spectre.Console" Version="0.54.0" />
    <PackageReference Include="System.CommandLine" Version="3.0.0-preview.2.26159.112" />
  </ItemGroup>

  <!-- Post-publish: rename output binary -->
  <Target Name="RenamePublishOutput" AfterTargets="Publish" Condition="'$(RuntimeIdentifier)' != ''">
    <PropertyGroup>
      <PublishedFile>$(PublishDir)$(AssemblyName)</PublishedFile>
      <RenamedFile>$(PublishDir)crypto-$(RuntimeIdentifier)</RenamedFile>
    </PropertyGroup>
    <Move SourceFiles="$(PublishedFile)" DestinationFiles="$(RenamedFile)" Condition="Exists('$(PublishedFile)')" />
    <Message Importance="High" Text="Renamed output to: $(RenamedFile)" />
  </Target>

</Project>
